PORT=5000
NODE_ENV=development

# Public API URL used by Swagger server metadata.
API_BASE_URL=http://localhost:5000

# Firebase Admin SDK
# Option 1: point to a local service account JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=

# Option 2: paste the full service account JSON as a single-line env value.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option 3: paste base64-encoded service account JSON, useful for hosts like Render.
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option 4: set individual service account fields.
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Fast2SMS WhatsApp OTP API
FAST2SMS_API_KEY=
MESSAGE_ID=
PHONE_NUMBER_ID=
FAST2SMS_WHATSAPP_API_URL=https://www.fast2sms.com/dev/whatsapp

# OTP settings
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# Rate limiting
TRUST_PROXY=false
API_RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_MAX_REQUESTS=100
OTP_SEND_RATE_LIMIT_WINDOW_MINUTES=15
OTP_SEND_RATE_LIMIT_MAX_REQUESTS=5
OTP_VERIFY_RATE_LIMIT_WINDOW_MINUTES=15
OTP_VERIFY_RATE_LIMIT_MAX_REQUESTS=10
